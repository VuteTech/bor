# Bor Agent Configuration
# Protect this file: chmod 0600 /etc/bor/config.yaml

server:
  # Server hostname or IP address (no port).
  address: "localhost"
  # Port for enrollment RPC and admin UI — no mandatory client certificate.
  # Agents connect here on first run to obtain their mTLS certificate.
  enrollment_port: 8443
  # Port for mTLS policy streaming and certificate renewal.
  # Requires a valid, non-revoked client certificate (RequireAndVerifyClientCert).
  policy_port: 8444
  # Skip server certificate verification during enrollment only.
  # Set to true when the server uses a self-signed certificate.
  # After enrollment, the CA cert is stored locally and used for verification.
  insecure_skip_verify: true

agent:
  # Unique client identifier (defaults to hostname if empty)
  client_id: ""

# Enrollment settings for mTLS bootstrap
enrollment:
  # Directory where the agent stores its certificate, key, and CA cert after enrollment
  data_dir: "/var/lib/bor/agent"
  # To enroll manually, run: bor-agent --token <TOKEN>
  # Generate a token from the Node Groups page in the Bor web UI.
  # Alternatively, enable Kerberos enrollment below for token-free enrollment.

# Kerberos token-free enrollment (optional, for domain-joined hosts).
#
# When enabled, the agent authenticates to the Bor server using the machine
# keytab (/etc/krb5.keytab) instead of a manually generated enrollment token.
# This works with FreeIPA and Active Directory (Samba AD) domain-joined hosts.
#
# Prerequisites:
#   - The host must be joined to the domain (ipa-client-install, realm join, etc.)
#   - The machine keytab must exist at keytab_file
#   - The Bor server must have Kerberos enrollment enabled (server.yaml kerberos.enabled)
#   - service_principal must match the Bor server's Kerberos service principal
#
# FreeIPA joined hosts: /etc/krb5.keytab is created automatically by ipa-client-install
# AD joined hosts:      /etc/krb5.keytab is created by realm join or adcli
#
#kerberos:
#  enabled: false
#  keytab_file: "/etc/krb5.keytab"
#  service_principal: "HTTP/bor.example.com@EXAMPLE.COM"
#  # kdc: hostname or IP of the Key Distribution Center (domain controller).
#  # When set, the agent builds its Kerberos config from this address and the
#  # realm in service_principal, bypassing /etc/krb5.conf entirely.
#  # Useful when /etc/krb5.conf is missing, incomplete, or uses syntax that
#  # the agent's Kerberos library does not support (e.g. on Fedora/RHEL).
#  # Example: "dc1.example.com" or "192.0.2.10"
#  kdc: ""
#  # machine_principal: the Kerberos principal for this machine's keytab entry.
#  # Default is "host/<hostname>" which is correct for FreeIPA-joined hosts.
#  # For AD / Samba AD hosts joined with realm(1) or adcli, the keytab usually
#  # contains "<HOSTNAME>$" (with dollar sign) or "host/<fqdn>@REALM".
#  # Run "klist -kte /etc/krb5.keytab" on the agent host to find the value.
#  machine_principal: ""

# Firefox policy output paths
firefox:
  # System Firefox (RPM/DEB package)
  policies_path: "/etc/firefox/policies/policies.json"
  # Flatpak Firefox — extension directory (auto-detected arch; leave empty to disable)
  # The agent writes here as root; Firefox Flatpak mounts it at /app/etc/firefox/ inside the sandbox.
  flatpak_policies_path: "/var/lib/flatpak/extension/org.mozilla.firefox.systemconfig/x86_64/stable/policies/policies.json"

# Chrome/Chromium policy directories
# The agent writes bor_managed.json into each configured directory.
# Set any path to "" to disable writing to that variant.
chrome:
  # Google Chrome (stable, beta, dev, unstable — all channels share this path)
  chrome_policies_path: "/etc/opt/chrome/policies/managed"
  # Chromium (upstream build: Arch Linux, self-built, etc.)
  chromium_policies_path: "/etc/chromium/policies/managed"
  # Chromium (Debian/Ubuntu deb package)
  chromium_browser_policies_path: "/etc/chromium-browser/policies/managed"
  # Flatpak Chromium (org.chromium.Chromium) — set empty to disable
  flatpak_chromium_policies_path: "/var/lib/flatpak/extension/org.chromium.Chromium.Extension.system-policies/x86_64/1/policies/managed"

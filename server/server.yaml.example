# Bor Policy Management Server — primary configuration
#
# Installed to /etc/bor/server.yaml (mode 640, owner root:bor).
# Environment variables take precedence over this file when set.
# Missing fields fall back to built-in defaults.
#
# On first install the post-install script patches database.host to the
# local PostgreSQL socket path and generates a random jwt_secret.
# Review and adjust before starting the service.

server:
  # Server hostname or IP address (no port). Leave empty to listen on all interfaces.
  address: ""

  # Port for the admin UI and enrollment gRPC (default: 8443).
  # Browsers and agents connecting for the first time use this port.
  enrollment_port: 8443

  # Port for mTLS policy streaming and certificate renewal (default: 8444).
  # Only enrolled agents with a valid, non-revoked client certificate are accepted.
  policy_port: 8444

  # Additional hostnames and IP addresses to include as Subject Alternative
  # Names in the auto-generated TLS certificate. The system hostname,
  # "localhost", 127.0.0.1, and ::1 are always included automatically.
  # Add your server's FQDN and any DNS aliases.
  #
  # Ignored when acme is enabled (the ACME cert covers exactly the listed domains).
  #
  #hostnames:
  #  - "bor.example.com"
  #  - "bor.internal"
  #  - "192.0.2.10"

database:
  # Unix socket directory for local PostgreSQL (peer auth — no password needed).
  # The post-install script sets this to the socket found on your distribution.
  # For a remote PostgreSQL instance replace with the hostname and set password.
  host: "/var/run/postgresql"
  port: 5432
  user: "bor"
  # password: ""   # not required for Unix socket / peer auth
  #                # for TCP connections: set to the bor role's password
  name: "bor"
  sslmode: "disable"   # use "require" for TCP connections to a remote server

  # Remote PostgreSQL example (replace host above and uncomment):
  #host: "db.example.com"
  #port: 5432
  #user: "bor"
  #password: "change-me"
  #name: "bor"
  #sslmode: "require"

security:
  # JWT signing secret. Auto-generated on first install by the post-install script.
  # Changing this value invalidates all active browser sessions.
  # Minimum 32 characters; use a cryptographically random string.
  jwt_secret: "change-me-in-production"

  # JWT access token lifetime (default: 1h). Short-lived; the refresh token
  # extends sessions without re-authentication.
  #jwt_lifetime: "1h"

  # Refresh token lifetime (default: 24h). Stored in an httpOnly cookie.
  #refresh_lifetime: "24h"

  # Static admin token for gRPC enrollment calls (optional).
  # Leave empty to require a web-UI-generated one-time enrollment token.
  admin_token: ""

  # Initial admin account password (used only on first startup when no users exist).
  # On package installs this is set by the post-install script; a random password
  # is generated and written here. Leave empty to have the server generate one at
  # runtime and print it to the log.
  #admin_password: ""

tls:
  # Paths to an externally-managed TLS certificate and private key.
  # If empty, the server auto-generates a certificate signed by the
  # internal CA and stores it in autogen_dir.
  #
  # Mutually exclusive with the acme section below.
  cert_file: ""
  key_file:  ""
  autogen_dir: "/var/lib/bor/pki/ui"

ca:
  # Paths to the internal CA certificate and private key used to sign
  # agent mTLS certificates. If empty, the server auto-generates a CA
  # and stores it in autogen_dir.
  cert_file: ""
  key_file:  ""
  autogen_dir: "/var/lib/bor/pki/ca"

  # Optional: store the CA private key in a PKCS#11 HSM instead of a file.
  # Requires the server binary to be built with: make server-pkcs11
  # Set the PIN via the BOR_CA_PKCS11_PIN environment variable — do not
  # store it in this file.
  #
  #pkcs11:
  #  lib: "/usr/lib/softhsm/libsofthsm2.so"
  #  token_label: "bor-ca"
  #  key_label: "bor-ca-key"

# ACME automatic TLS certificate (Let's Encrypt or any RFC 8555-compatible CA).
#
# When enabled, the server obtains and renews a publicly-trusted certificate
# automatically. Requires a domain name reachable by the ACME CA on port 80
# (HTTP-01 challenge) or port 443 (TLS-ALPN-01).
#
# Mutually exclusive with tls.cert_file / tls.key_file.
# See docs/acme.md for full documentation.
#
#acme:
#  enabled: true
#  domains:
#    - "bor.example.com"
#  email: "admin@example.com"
#  # directory_url defaults to Let's Encrypt production when omitted.
#  # Staging (not browser-trusted, for testing):
#  #   https://acme-staging-v02.api.letsencrypt.org/directory
#  # ZeroSSL: https://acme.zerossl.com/v2/DV90
#  # Buypass:  https://api.buypass.com/acme/directory
#  # directory_url: "https://acme-v02.api.letsencrypt.org/directory"
#  # cache_dir: "/var/lib/bor/acme"
#  # http_port: 80

# LDAP / Active Directory authentication (optional).
#
# Supports FreeIPA (MIT Kerberos, 389 DS back-end) and Active Directory /
# Samba AD out of the box.
ldap:
  enabled: false
  host: "ldap.example.com"
  port: 389
  use_tls: false
  start_tls: false
  tls_ca_file: ""
  bind_dn: "cn=readonly,dc=example,dc=com"
  # Set via LDAP_BIND_PASSWORD env var rather than storing here.
  bind_password: ""
  base_dn: "dc=example,dc=com"
  # FreeIPA: "(uid=%s)"   AD: "(sAMAccountName=%s)"
  user_filter: "(uid=%s)"
  upn_suffix: ""           # AD UPN fallback, e.g. "@EXAMPLE.COM"
  attr_username: "uid"     # AD: sAMAccountName
  attr_email: "mail"
  attr_full_name: "cn"     # AD: displayName
  group_base_dn: ""
  group_filter: ""
  group_member_attr: "member"
  attr_member_of: "memberOf"
  page_size: 500

  # Map LDAP group CNs to Bor role names (synced on every login).
  # Only roles listed here are managed; manually assigned roles are preserved.
  # Available roles: Super Admin, Org Admin, Policy Editor, Policy Reviewer,
  #                  Compliance Viewer, Auditor
  #group_role_map:
  #  "Domain Admins": "Super Admin"
  #  "IT Staff": "Org Admin"

# Active Directory / Samba AD example (uncomment and adapt):
#ldap:
#  enabled: true
#  host: "dc01.example.com"
#  port: 636
#  use_tls: true
#  tls_ca_file: "/etc/ssl/certs/example-ca.crt"
#  bind_dn: "CN=bor-svc,CN=Users,DC=example,DC=com"
#  bind_password: ""   # set via LDAP_BIND_PASSWORD env var
#  base_dn: "DC=example,DC=com"
#  user_filter: "(sAMAccountName=%s)"
#  upn_suffix: "@EXAMPLE.COM"
#  attr_username: "sAMAccountName"
#  attr_email: "mail"
#  attr_full_name: "displayName"
#  group_filter: "(&(objectClass=group)(member=%s))"
#  group_member_attr: "member"
#  attr_member_of: "memberOf"
#  page_size: 1000

# FreeIPA example (uncomment and adapt):
#ldap:
#  enabled: true
#  host: "ipa.example.com"
#  port: 636
#  use_tls: true
#  tls_ca_file: "/etc/ipa/ca.crt"
#  bind_dn: "uid=bor-svc,cn=users,cn=accounts,dc=example,dc=com"
#  bind_password: ""   # set via LDAP_BIND_PASSWORD env var
#  base_dn: "dc=example,dc=com"
#  user_filter: "(uid=%s)"
#  attr_username: "uid"
#  attr_email: "mail"
#  attr_full_name: "cn"
#  group_filter: "(&(objectClass=groupofnames)(member=%s))"
#  group_member_attr: "member"
#  attr_member_of: "memberOf"
#  page_size: 500

# Kerberos token-free agent enrollment (optional).
#
#kerberos:
#  enabled: false
#  realm: "EXAMPLE.COM"
#  keytab_file: "/etc/bor/krb5.keytab"
#  service_principal: "HTTP/bor.example.com@EXAMPLE.COM"
#  default_node_group_id: ""   # UUID of the node group for auto-enrolled agents

# WebAuthn / FIDO2 hardware security keys (optional).
#
#webauthn:
#  rpid: "bor.example.com"
#  origins:
#    - "https://bor.example.com"
#  display_name: "Bor Policy Manager"

# Prometheus metrics endpoint (plain HTTP, separate port).
#
#metrics:
#  listen_addr: "127.0.0.1:9090"
#  bearer_token: ""
#  # tls_cert_file: "/etc/bor/metrics.crt"
#  # tls_key_file:  "/etc/bor/metrics.key"

# Audit log settings.
#
#audit:
#  retention_days: 365
#  # anonymize_ips: false   # truncate IPs to /24 (v4) or /48 (v6) — GDPR minimisation
#  syslog:
#    enabled: false
#    network: "udp"                   # udp | tcp | tcp+tls
#    addr: "siem.example.com:514"
#    format: "cef"                    # cef (ArcSight) | ocsf (JSON, OCSF v1.3)
#    facility: 16                     # RFC 5424 facility code (16 = local0)
#    tls_ca: ""                       # PEM CA for tcp+tls server verification

# UI settings.
#
#ui:
#  # Show a Privacy Policy link in the sidebar footer (GDPR Article 13).
#  privacy_policy_url: "https://example.com/privacy"

# Example environment configuration
# Copy this file to .env and customize for your environment

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=bor
DB_PASSWORD=bor
DB_NAME=bor
DB_SSLMODE=disable

# Server Configuration
# Server hostname or IP (no port). Leave empty to listen on all interfaces.
# BOR_ADDRESS=
# Port for the admin UI and enrollment gRPC (default: 8443).
BOR_ENROLLMENT_PORT=8443
# Port for mTLS policy streaming and certificate renewal (default: 8444).
# Must be reachable by enrolled agents. Open this port in any firewall between
# the server and managed desktops.
BOR_POLICY_PORT=8444
# Additional hostnames/IPs for the auto-generated TLS certificate SANs.
# Comma-separated. Overrides the 'hostnames' list in server.yaml when set.
# BOR_HOSTNAMES=bor.example.com,192.0.2.10

# Security
JWT_SECRET=change-me-in-production

# PKCS#11 HSM for CA private key (optional; requires make server-pkcs11)
# BOR_CA_PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so
# BOR_CA_PKCS11_TOKEN_LABEL=bor-ca
# BOR_CA_PKCS11_KEY_LABEL=bor-ca-key
# BOR_CA_PKCS11_PIN=
TLS_ENABLED=false
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem

# Default Admin (only used when no users exist on first startup)
BOR_ADMIN_PASSWORD=change-me-in-production

# Kerberos token-free agent enrollment (optional, for domain-joined hosts)
# When enabled, agents on domain-joined desktops can enroll automatically using
# their machine keytab (/etc/krb5.keytab) without a manually generated token.
# BOR_KERBEROS_DEFAULT_NODE_GROUP: UUID of the node group for auto-enrolled agents.
# Copy it from Node Groups → Edit (Group ID field) in the web UI.
# BOR_KERBEROS_ENABLED=false
# BOR_KERBEROS_REALM=EXAMPLE.COM
# BOR_KERBEROS_KEYTAB=/etc/bor/krb5.keytab
# BOR_KERBEROS_PRINCIPAL=HTTP/bor.example.com@EXAMPLE.COM
# BOR_KERBEROS_DEFAULT_NODE_GROUP=

# LDAP Configuration
LDAP_ENABLED=false
LDAP_HOST=localhost
LDAP_PORT=389
LDAP_USE_TLS=false
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_FILTER=(uid=%s)
LDAP_ATTR_USERNAME=uid
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_FULL_NAME=cn

# Prometheus Metrics
# Listen address for the Prometheus /metrics endpoint (plain HTTP).
# Defaults to 127.0.0.1:9090 — only reachable from localhost.
# Set to a management interface IP to allow remote scraping, e.g.:
#   BOR_METRICS_ADDR=192.168.1.10:9090   # management VLAN only
#   BOR_METRICS_ADDR=:9090               # all interfaces (protect with firewall)
# BOR_METRICS_ADDR=127.0.0.1:9090
#
# Optional bearer token. When set, every Prometheus scrape must include
# "Authorization: Bearer <token>". Leave unset if the listener is localhost-only.
# BOR_METRICS_TOKEN=

# Audit syslog forwarding
# When BOR_AUDIT_SYSLOG_ENABLED=true, every audit event is forwarded to the
# configured syslog receiver using RFC 5424 framing.
# BOR_AUDIT_SYSLOG_ENABLED=false
# BOR_AUDIT_SYSLOG_NETWORK=udp          # udp | tcp | tcp+tls
# BOR_AUDIT_SYSLOG_ADDR=localhost:514   # host:port of the syslog receiver
# BOR_AUDIT_SYSLOG_FORMAT=cef           # cef (ArcSight) | ocsf (JSON, OCSF v1.3)
# BOR_AUDIT_SYSLOG_FACILITY=16          # RFC 5424 facility code (16 = local0)
# BOR_AUDIT_SYSLOG_TLS_CA=              # PEM CA file for tcp+tls verification

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Frontend
FRONTEND_URL=http://localhost:3000

# Agent Configuration (for agent deployment)
SERVER_ADDRESS=localhost:8443
CLIENT_ID=desktop-01
AUTO_UPDATE=true
